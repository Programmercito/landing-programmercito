---
import EmailIcon from "../../components/icons/EmailIcon.astro";
import GithubIcon from "../../components/icons/GithubIcon.astro";
import LinkedinIcon from "../../components/icons/LinkedinIcon.astro";

// Obtener cantidad de repositorios de GitHub
let repoCount = 0;
try {
  const res = await fetch("https://api.github.com/users/programmercito?per_page=1");
  if (res.ok) {
    const data = await res.json();
    repoCount = data.public_repos || 0;
  }
} catch (_) {}
---

<section 
  class="relative min-h-screen flex flex-col items-center justify-center px-4 sm:px-6 md:px-8 py-16 max-w-6xl mx-auto overflow-hidden"
  id="perfil-hero"
>
  <!-- Lineas decorativas de codigo en el fondo -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden opacity-[0.04]">
    <div class="code-rain absolute top-0 left-[10%] text-accent-200 text-xs font-mono leading-6 whitespace-pre" set:html={`const dev = {\n  name: "Joaquin",\n  role: "Senior Engineer",\n  experience: "15+ years",\n  passion: "building things"\n};`}>
    </div>
    <div class="code-rain-2 absolute top-[20%] right-[5%] text-primary-300 text-xs font-mono leading-6 whitespace-pre" set:html={`function solve(problem) {\n  return creativity\n    .combine(experience)\n    .deploy();\n}`}>
    </div>
    <div class="code-rain-3 absolute bottom-[15%] left-[5%] text-accent-200 text-xs font-mono leading-6 whitespace-pre" set:html={`while (alive) {\n  eat();\n  sleep();\n  code();\n  repeat();\n}`}>
    </div>
  </div>

  <!-- Contenido principal -->
  <div class="relative z-10 flex flex-col md:flex-row items-center justify-between w-full gap-8 md:gap-12">
    
    <!-- Texto y botones -->
    <div class="order-2 md:order-1 md:w-3/5 text-center md:text-left">
      
      <!-- Terminal-like greeting -->
      <div class="reveal stagger-1 mb-3">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-bg-100/60 border border-primary-200/20 backdrop-blur-sm font-mono">
          <span class="text-primary-300 text-sm">~$</span>
          <span class="hero-typing text-accent-200 text-sm">Hola, me llamo</span>
          <span class="terminal-cursor text-accent-200">|</span>
        </div>
      </div>
      
      <!-- Nombre con gradiente animado y efecto glitch -->
      <h1 class="reveal stagger-2 text-5xl md:text-7xl font-bold mb-4 leading-tight">
        <span class="text-gradient-animated text-glitch cursor-default">Joaquin</span>
      </h1>
      
      <!-- Titulo con efecto de status badge -->
      <div class="reveal stagger-3 mb-5 flex flex-wrap gap-2 justify-center md:justify-start">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-100/30 border border-primary-200/20 backdrop-blur-sm neon-glow">
          <span class="status-dot w-2 h-2 rounded-full bg-[#22c55e]" />
          <span class="text-accent-200 font-medium text-xs">Available for work</span>
        </div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-bg-200/50 border border-primary-200/10 backdrop-blur-sm">
          <span class="text-text-200/80 font-medium text-xs">Software Senior Engineer</span>
        </div>
      </div>

      <!-- Descripcion -->
      <p class="reveal stagger-4 mb-5 text-left md:text-justify text-sm leading-relaxed text-text-200/80 max-w-lg">
        Con m&aacute;s de <span class="text-accent-200 font-semibold">15 a&ntilde;os de experiencia</span>, siempre a la vanguardia de los
        lenguajes y frameworks en tecnolog&iacute;a. He trabajado en el desarrollo de
        aplicaciones altamente escalables en el <span class="text-primary-300 font-medium">&aacute;rea financiera p&uacute;blica de Bolivia</span>
        utilizando Java, PHP, TypeScript, JavaScript y Oracle.
      </p>

      <!-- Redes sociales + Stats en linea -->
      <div class="reveal stagger-5 flex flex-col gap-4">
        <!-- Botones sociales -->
        <div class="flex flex-col justify-center gap-2.5 md:flex-row md:justify-start">
          <a
            href="https://www.linkedin.com/in/joaquin-h-m/"
            target="_blank"
            class="social-btn group inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-primary-200/30 justify-center
                   bg-bg-200/50 backdrop-blur-sm
                   transition-all duration-500
                   hover:bg-[#0077b5]/20 hover:border-[#0077b5]/50 hover:scale-105 hover:shadow-[0_0_30px_rgba(0,119,181,0.3)]
                   ripple-effect"
          >
            <LinkedinIcon />
            <span class="font-medium text-sm">LinkedIn</span>
          </a>

          <a
            href="https://github.com/programmercito"
            target="_blank"
            class="social-btn group inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-primary-200/30 justify-center
                   bg-bg-200/50 backdrop-blur-sm
                   transition-all duration-500
                   hover:bg-bg-300/80 hover:border-text-200/30 hover:scale-105 hover:shadow-[0_0_30px_rgba(75,85,99,0.3)]
                   ripple-effect"
          >
            <GithubIcon />
            <span class="font-medium text-sm">GitHub</span>
          </a>

          <a
            href="mailto:devicitobo@outlook.com"
            target="_blank"
            class="social-btn group inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-primary-200/30 justify-center
                   bg-bg-200/50 backdrop-blur-sm
                   transition-all duration-500
                   hover:bg-[#22c55e]/20 hover:border-[#22c55e]/50 hover:scale-105 hover:shadow-[0_0_30px_rgba(34,197,94,0.3)]
                   ripple-effect"
          >
            <EmailIcon />
            <span class="font-medium text-sm">Email</span>
          </a>
        </div>

        <!-- Stats pegados a los botones -->
        <div class="grid grid-cols-4 gap-2.5 max-w-md mx-auto md:mx-0">
          <div class="stat-card text-center p-2.5 rounded-xl bg-bg-200/30 border border-primary-200/10 backdrop-blur-sm hover:border-primary-200/30 transition-all duration-300 hover:scale-105 group cursor-default">
            <div class="text-xl font-bold text-gradient group-hover:scale-110 transition-transform">15+</div>
            <div class="text-[10px] text-text-200/60 uppercase tracking-wider">A&ntilde;os Exp.</div>
          </div>
          <div class="stat-card text-center p-2.5 rounded-xl bg-bg-200/30 border border-primary-200/10 backdrop-blur-sm hover:border-primary-200/30 transition-all duration-300 hover:scale-105 group cursor-default">
            <div class="text-xl font-bold text-gradient group-hover:scale-110 transition-transform">10</div>
            <div class="text-[10px] text-text-200/60 uppercase tracking-wider">Proyectos</div>
          </div>
          <div class="stat-card text-center p-2.5 rounded-xl bg-bg-200/30 border border-primary-200/10 backdrop-blur-sm hover:border-primary-200/30 transition-all duration-300 hover:scale-105 group cursor-default">
            <div class="text-xl font-bold text-gradient group-hover:scale-110 transition-transform">23</div>
            <div class="text-[10px] text-text-200/60 uppercase tracking-wider">Tecnolog&iacute;as</div>
          </div>
          <div class="stat-card text-center p-2.5 rounded-xl bg-bg-200/30 border border-primary-200/10 backdrop-blur-sm hover:border-primary-200/30 transition-all duration-300 hover:scale-105 group cursor-default">
            <div class="text-xl font-bold text-gradient group-hover:scale-110 transition-transform">{repoCount > 0 ? `${repoCount}+` : '60+'}</div>
            <div class="text-[10px] text-text-200/60 uppercase tracking-wider">Repositorios</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Imagen de perfil con efectos -->
    <div class="order-1 md:order-2 flex justify-center reveal animate-fade-in-scale">
      <div class="relative group">
        <!-- Anillo exterior con gradiente animado -->
        <div class="absolute -inset-4 rounded-full hero-ring-outer opacity-60" />
        
        <!-- Anillos decorativos animados -->
        <div class="absolute inset-0 rounded-full border-2 border-primary-200/20 animate-pulse-glow scale-110" />
        <div class="absolute inset-0 rounded-full border border-accent-200/10 scale-125 animate-float animation-delay-500" />
        
        <!-- Contenedor de imagen -->
        <div class="relative w-44 h-44 md:w-60 md:h-60 rounded-full overflow-hidden ring-4 ring-primary-200/20 
                    shadow-[0_0_60px_rgba(61,90,128,0.4)] transition-all duration-700 
                    group-hover:shadow-[0_0_80px_rgba(61,90,128,0.6)] group-hover:scale-105
                    electric-hover">
          <img
            src="/images/me.jpeg"
            alt="Joaquin"
            loading="eager"
            decoding="async"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <!-- Overlay scan -->
          <div class="absolute inset-0 bg-gradient-to-t from-primary-100/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 scan-effect" />
        </div>
        
        <!-- Badge Full Stack -->
        <div class="absolute -bottom-2 -right-2 bg-bg-200 border border-primary-200/30 rounded-full px-3 py-1 shadow-lg neon-glow">
          <span class="text-xs font-medium text-accent-200">Full Stack</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Decoracion de fondo -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-primary-100/20 rounded-full blur-[100px] pointer-events-none" />
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent-100/10 rounded-full blur-[120px] pointer-events-none" />
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-200/5 rounded-full blur-[150px] pointer-events-none" />
</section>

<style>
  /* Terminal cursor blink */
  .terminal-cursor {
    animation: cursorBlink 1s step-end infinite;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Hero typing effect */
  .hero-typing {
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    animation: heroType 1.5s steps(16) 0.5s forwards;
  }

  @keyframes heroType {
    from { width: 0; }
    to { width: 100%; }
  }

  /* Status dot pulse */
  .status-dot {
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { 
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7);
    }
    50% { 
      box-shadow: 0 0 0 6px rgba(34, 197, 94, 0);
    }
  }

  /* Hero ring outer gradient */
  .hero-ring-outer {
    background: conic-gradient(
      from 0deg,
      rgba(172, 194, 239, 0.3),
      rgba(206, 232, 255, 0.1),
      rgba(61, 90, 128, 0.3),
      rgba(172, 194, 239, 0.1),
      rgba(206, 232, 255, 0.3)
    );
    animation: ringRotate 8s linear infinite;
  }

  @keyframes ringRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Code rain animations */
  .code-rain {
    animation: codeFloat1 20s linear infinite;
  }

  .code-rain-2 {
    animation: codeFloat2 25s linear infinite;
    animation-delay: 5s;
  }

  .code-rain-3 {
    animation: codeFloat3 22s linear infinite;
    animation-delay: 10s;
  }

  @keyframes codeFloat1 {
    0% { transform: translateY(0) translateX(0); opacity: 0.04; }
    25% { opacity: 0.06; }
    50% { transform: translateY(-30px) translateX(10px); opacity: 0.04; }
    75% { opacity: 0.05; }
    100% { transform: translateY(0) translateX(0); opacity: 0.04; }
  }

  @keyframes codeFloat2 {
    0% { transform: translateY(0) translateX(0); opacity: 0.03; }
    50% { transform: translateY(20px) translateX(-15px); opacity: 0.05; }
    100% { transform: translateY(0) translateX(0); opacity: 0.03; }
  }

  @keyframes codeFloat3 {
    0% { transform: translateY(0); opacity: 0.03; }
    50% { transform: translateY(-25px); opacity: 0.06; }
    100% { transform: translateY(0); opacity: 0.03; }
  }

  /* Efectos adicionales para botones sociales */
  .social-btn {
    position: relative;
    overflow: hidden;
  }

  .social-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.08),
      transparent
    );
    transition: left 0.5s;
  }

  .social-btn:hover::before {
    left: 100%;
  }

  /* Stats pulse */
  .stat-card {
    position: relative;
  }

  .stat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(
      100px circle at 50% 50%,
      rgba(172, 194, 239, 0.08),
      transparent 70%
    );
  }

  .stat-card:hover::after {
    opacity: 1;
  }

  /* Animation delay utilities */
  .animation-delay-500 {
    animation-delay: 0.5s;
  }
  
  .animation-delay-1000 {
    animation-delay: 1s;
  }
</style>
