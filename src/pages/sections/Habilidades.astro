---
import TitleSection from "../../components/opciones/TitleSection.astro";
import Section from "../../components/Section.astro";
import habilidades from "../../data/habilidades.json";
import Adf from "../../components/icons/Adf.astro";
import Angular from "../../components/icons/Angular.astro";
import Cicd from "../../components/icons/Cicd.astro";
import Devops from "../../components/icons/Devops.astro";
import Docker from "../../components/icons/Docker.astro";
import Fullstack from "../../components/icons/Fullstack.astro";
import Git from "../../components/icons/Git.astro";
import Java from "../../components/icons/Java.astro";
import Javascript from "../../components/icons/Javascript.astro";
import Kubernetes from "../../components/icons/Kubernetes.astro";
import Microservices from "../../components/icons/Microservices.astro";
import Mysql from "../../components/icons/Mysql.astro";
import Oracle from "../../components/icons/Oracle.astro";
import Php from "../../components/icons/Php.astro";
import Redis from "../../components/icons/Redis.astro";
import Scrum from "../../components/icons/Scrum.astro";
import Softarchi from "../../components/icons/Softarchi.astro";
import Sprintboot from "../../components/icons/Sprintboot.astro";
import Sql from "../../components/icons/Sql.astro";
import Sqlserver from "../../components/icons/Sqlserver.astro";
import Svn from "../../components/icons/Svn.astro";
import Typescript from "../../components/icons/Typescript.astro";
import Rest from "../../components/icons/Rest.astro";

const iconComponents = {
    Adf,
    Angular,
    Cicd,
    Devops,
    Docker,
    Fullstack,
    Git,
    Java,
    Javascript,
    Kubernetes,
    Microservices,
    Mysql,
    Oracle,
    Php,
    Redis,
    Scrum,
    Softarchi,
    Sprintboot,
    Sql,
    Sqlserver,
    Svn,
    Typescript,
    Rest,
};
---

<Section id="habilidades">
    <div class="order-2 md:order-1 text-center md:text-left w-full">
        <div class="reveal">
            <TitleSection>Habilidades</TitleSection>
        </div>

        <div class="reveal stagger-2 p-6 rounded-2xl border border-primary-200/10 bg-bg-200/40 backdrop-blur-sm shadow-lg w-full">
            <div class="flex flex-wrap gap-3 mt-4 justify-center">
                {
                    habilidades.map((habilidad, idx) => {
                        const Icon =
                            iconComponents[
                                habilidad.icon as keyof typeof iconComponents
                            ];
                        return (
                            <div class={`skill-item group relative`} style={`animation-delay: ${idx * 50}ms`}>
                                <div class="skill-card w-20 h-20 sm:w-24 sm:h-24 flex flex-col items-center justify-center p-2 rounded-xl bg-bg-100/30 border border-primary-200/5 
                                            transition-all duration-300 hover:border-primary-200/30 hover:bg-bg-100/50 
                                            hover:scale-110 hover:shadow-[0_0_20px_rgba(61,90,128,0.3)] relative overflow-visible">
                                    <div class="w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center text-text-200/70 group-hover:text-accent-200 transition-colors duration-300">
                                        {Icon && <Icon />}
                                    </div>
                                    
                                    {/* Tooltip dentro de la tarjeta */}
                                    <div class="absolute bottom-1 left-1/2 -translate-x-1/2 px-2 py-0.5 rounded bg-bg-100/90 border border-primary-200/20 text-text-100 text-[10px] font-medium
                                                opacity-0 group-hover:opacity-100 transition-all duration-200 whitespace-nowrap z-20">
                                        {habilidad.name}
                                    </div>
                                </div>
                            </div>
                        );
                    })
                }
            </div>
        </div>
    </div>
</Section>

<style>
    .skill-item {
        animation: skillFadeIn 0.5s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }
    
    @keyframes skillFadeIn {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .skill-card {
        position: relative;
    }
    
    .skill-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(
            100px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
            rgba(172, 194, 239, 0.15),
            transparent 40%
        );
        opacity: 0;
        transition: opacity 0.3s;
        border-radius: inherit;
    }
    
    .skill-card:hover::before {
        opacity: 1;
    }
</style>

<script is:inline>
    document.querySelectorAll('.skill-card').forEach(card => {
        card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            card.style.setProperty('--mouse-x', `${x}px`);
            card.style.setProperty('--mouse-y', `${y}px`);
        });
    });
</script>
