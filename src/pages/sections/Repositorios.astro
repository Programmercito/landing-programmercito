---
import BordeadoIcon from "../../components/opciones/BordeadoIcon.astro";
import TitleSection from "../../components/opciones/TitleSection.astro";
import Section from "../../components/Section.astro";
import CodeIcon from "../../components/icons/CodeIcon.astro";
import RepositorioCard from "../../components/opciones/RepositorioCard.astro";

// Consumir la API de GitHub y guardar los datos principales en una lista
type GithubRepo = {
  id: number;
  name: string;
  html_url: string;
  description: string | null;
  language: string | null;
  stargazers_count: number;
  forks_count: number;
  updated_at: string;
};

// Consumir la API de GitHub con manejo de errores
let repos: GithubRepo[] = [];
let apiError = false;

try {
  const response = await fetch(
    "https://api.github.com/users/programmercito/repos?per_page=100&sort=updated",
  );
  
  if (response.ok) {
    const data = await response.json();
    // Verificar que data sea un array
    if (Array.isArray(data)) {
      repos = data.map((repo: GithubRepo) => ({
        id: repo.id,
        name: repo.name,
        html_url: repo.html_url,
        description: repo.description,
        language: repo.language,
        stargazers_count: repo.stargazers_count,
        forks_count: repo.forks_count,
        updated_at: repo.updated_at,
      }));
    } else {
      console.error("La respuesta de GitHub no es un array:", data);
      apiError = true;
    }
  } else {
    console.error("Error en la respuesta de GitHub:", response.status, response.statusText);
    apiError = true;
  }
} catch (error) {
  console.error("Error al obtener repositorios de GitHub:", error);
  apiError = true;
}
---

<Section id="repositorios">
  <div class="order-2 md:order-1 text-center md:text-left w-full">
    <div class="reveal">
      <TitleSection>Repositorios</TitleSection>
    </div>

    {apiError && repos.length === 0 ? (
      <div class="reveal p-8 rounded-2xl border border-primary-200/10 bg-bg-200/40 backdrop-blur-sm text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4 text-primary-300/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <p class="text-text-200/80 text-sm leading-relaxed mb-2">No se pudieron cargar los repositorios en este momento.</p>
        <a href="https://github.com/programmercito" target="_blank" class="inline-flex items-center gap-2 text-accent-200 hover:text-text-100 transition-colors text-sm">
          Ver repositorios en GitHub
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    ) : (
    <div class="grid gap-6 grid-cols-1 md:grid-cols-3 items-stretch">
      {repos.slice(0, 9).map((repo, idx) => (
        <div class={`reveal stagger-${(idx % 6) + 1} animation-delay-${idx * 50}`}>
          <a 
            href={repo.html_url}
            target="_blank"
            class="repo-card block h-full p-5 rounded-2xl border border-primary-200/10 bg-bg-200/40 backdrop-blur-sm 
                   transition-all duration-500 hover:border-primary-200/30 hover:bg-bg-200/60 
                   hover:shadow-[0_0_40px_rgba(31,58,95,0.2)] hover:-translate-y-1 group"
          >
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-2 min-w-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
                <h3 
                  class="text-base font-semibold text-text-100 group-hover:text-accent-200 transition-colors truncate"
                  title={repo.name}
                >
                  {repo.name}
                </h3>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-text-200/40 group-hover:text-text-200 transition-all group-hover:translate-x-1 group-hover:-translate-y-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </div>
            
            <p class="text-text-200/80 text-sm leading-relaxed mb-4">
              {repo.description || "Sin descripci\u00f3n disponible"}
            </p>
            
            <div class="flex items-center justify-between text-sm text-text-200/60">
              <div class="flex items-center gap-3">
                {repo.language && (
                  <span class="flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full bg-accent-200"></span>
                    {repo.language}
                  </span>
                )}
              </div>
              
              <div class="flex items-center gap-3">
                {repo.stargazers_count > 0 && (
                  <span class="flex items-center gap-1" title={`${repo.stargazers_count} estrellas`}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    {repo.stargazers_count}
                  </span>
                )}
                {repo.forks_count > 0 && (
                  <span class="flex items-center gap-1" title={`${repo.forks_count} forks`}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
                    </svg>
                    {repo.forks_count}
                  </span>
                )}
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
    
    <div class="reveal flex justify-end mt-6 gap-3">
      <BordeadoIcon link="#repositorios-more" id="repositorios-more-btn">
        Ver m&aacute;s repositorios
      </BordeadoIcon>
    </div>
    
    <div class="hidden" id="repositorios-more">
      <div class="grid gap-6 grid-cols-1 md:grid-cols-3 items-stretch mt-6">
        {repos.slice(9).map((repo, idx) => (
          <div class="reveal">
            <a 
              href={repo.html_url}
              target="_blank"
              class="repo-card block h-full p-4 sm:p-5 rounded-xl sm:rounded-2xl border border-primary-200/10 bg-bg-200/40 backdrop-blur-sm 
                     transition-all duration-500 hover:border-primary-200/30 hover:bg-bg-200/60 
                     hover:shadow-[0_0_40px_rgba(31,58,95,0.2)] hover:-translate-y-1 group"
            >
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2 min-w-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                  <h3 
                    class="font-semibold text-text-100 group-hover:text-accent-200 transition-colors truncate"
                    title={repo.name}
                  >
                    {repo.name.length > 20 ? repo.name.substring(0, 20) + '...' : repo.name}
                  </h3>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-text-200/40 group-hover:text-text-200 transition-all group-hover:translate-x-1 group-hover:-translate-y-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
              
              <p class="text-text-200/80 text-sm leading-relaxed mb-4">
                {repo.description || "Sin descripci\u00f3n disponible"}
              </p>
              
              <div class="flex items-center justify-between text-xs text-text-200/60">
                <div class="flex items-center gap-2 sm:gap-3">
                  {repo.language && (
                    <span class="flex items-center gap-1">
                      <span class="w-2 h-2 rounded-full bg-accent-200"></span>
                      <span class="hidden sm:inline">{repo.language}</span>
                      <span class="sm:hidden">{repo.language.length > 6 ? repo.language.substring(0, 6) : repo.language}</span>
                    </span>
                  )}
                </div>
                
                <div class="flex items-center gap-2 sm:gap-3">
                  {repo.stargazers_count > 0 && (
                    <span class="flex items-center gap-1" title={`${repo.stargazers_count} estrellas`}>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                      <span class="hidden sm:inline">{repo.stargazers_count}</span>
                    </span>
                  )}
                  {repo.forks_count > 0 && (
                    <span class="flex items-center gap-1" title={`${repo.forks_count} forks`}>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
                      </svg>
                      <span class="hidden sm:inline">{repo.forks_count}</span>
                    </span>
                  )}
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
    
    <div class="justify-end mt-4 hidden" id="repositorios-menos">
      <BordeadoIcon link="#repositorios" id="repositorios-menos-btn">
        Ocultar
      </BordeadoIcon>
    </div>
    )}
  </div>
</Section>

<style>
  .repo-card {
    position: relative;
  }
  
  .repo-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      200px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(172, 194, 239, 0.1),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.3s;
    border-radius: inherit;
    pointer-events: none;
  }
  
  .repo-card:hover::before {
    opacity: 1;
  }

  /* Animation delay utilities */
  .animation-delay-0 { animation-delay: 0ms; }
  .animation-delay-50 { animation-delay: 50ms; }
  .animation-delay-100 { animation-delay: 100ms; }
  .animation-delay-150 { animation-delay: 150ms; }
  .animation-delay-200 { animation-delay: 200ms; }
  .animation-delay-250 { animation-delay: 250ms; }
  .animation-delay-300 { animation-delay: 300ms; }
  .animation-delay-350 { animation-delay: 350ms; }
  .animation-delay-400 { animation-delay: 400ms; }
  .animation-delay-450 { animation-delay: 450ms; }
  .animation-delay-500 { animation-delay: 500ms; }
  .animation-delay-550 { animation-delay: 550ms; }
  .animation-delay-600 { animation-delay: 600ms; }
</style>

<script>
  const btn = document.getElementById("repositorios-more-btn");
  const more = document.getElementById("repositorios-more");
  const btnMenos = document.getElementById("repositorios-menos-btn");
  const menos = document.getElementById("repositorios-menos");
  if (btn && more && menos) {
    btn.addEventListener("click", () => {
      more.classList.remove("hidden");
      btn.classList.add("hidden");
      menos.classList.remove("hidden");
      menos.classList.add("flex");
    });
  }
  if (btnMenos && menos && more) {
    btnMenos.addEventListener("click", () => {
      more.classList.add("hidden");
      btn?.classList.remove("hidden");
      menos.classList.add("hidden");
      menos.classList.remove("flex");
    });
  }
  
  // Efecto de seguimiento del mouse
  document.querySelectorAll('.repo-card').forEach(card => {
    card.addEventListener('mousemove', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      const htmlCard = card as HTMLElement;
      const rect = htmlCard.getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left;
      const y = mouseEvent.clientY - rect.top;
      htmlCard.style.setProperty('--mouse-x', `${x}px`);
      htmlCard.style.setProperty('--mouse-y', `${y}px`);
    });
  });
</script>
