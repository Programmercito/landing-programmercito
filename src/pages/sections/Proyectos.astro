---
import BordeadoIcon from "../../components/opciones/BordeadoIcon.astro";
import Chip from "../../components/opciones/Chip.astro";
import TitleSection from "../../components/opciones/TitleSection.astro";
import Section from "../../components/Section.astro";
import links from "../../data/proyectos.json";
import CodeIcon from "../../components/icons/CodeIcon.astro";
import DeployIcon from "../../components/icons/DeployIcon.astro";
---

<Section id="proyectos">
  <div class="order-2 md:order-1 text-center md:text-left">
    <div class="reveal">
      <TitleSection>Proyectos</TitleSection>
    </div>

    <div class="grid gap-8 md:grid-cols-2 items-stretch">
      {
        links.map((link, idx) => (
          <div 
            class={`w-full h-full flex reveal stagger-${(idx % 6) + 1} animation-delay-${idx * 100}`}
          >
            <div class="project-card flex flex-col rounded-2xl w-full h-full overflow-hidden group">
              {/* Header con título y tecnologías */}
              <div class="p-5 pb-3">
                <div class="flex justify-center mb-2">
                  <h3 class="text-xl md:text-2xl font-bold text-gradient text-center">{link.name}</h3>
                </div>
                
                <p class="text-left leading-relaxed tracking-wide mb-4 text-text-200/80 text-sm">
                  {link.description}
                </p>

                {/* Tech chips */}
                {link.tech && link.tech.length > 0 && (
                  <div class="flex flex-wrap gap-2 justify-center mb-4">
                    {link.tech.map((tec) => (
                      <Chip text={tec} />
                    ))}
                  </div>
                )}
              </div>

              {/* Galería de imágenes mejorada */}
              {link.images && link.images.length > 0 && (
                <div class="relative px-5">
                  <div class="image-gallery relative overflow-hidden rounded-xl bg-bg-100/50">
                    {/* Imagen principal clickeable */}
                    <div 
                      class="gallery-main relative aspect-video cursor-pointer group/image"
                      onclick={`abrirPopup('${link.images[0]}', ${idx})`}
                    >
                      <img
                        id={`main-img-${idx}`}
                        src={link.images[0]}
                        alt={link.name}
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover transition-all duration-500 group-hover/image:scale-105"
                      />
                      {/* Overlay con gradiente */}
                      <div class="absolute inset-0 bg-gradient-to-t from-bg-100/80 via-transparent to-transparent opacity-60 group-hover/image:opacity-40 transition-opacity duration-300" />
                      
                      {/* Indicador de clickeable - aparece en hover */}
                      <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/image:opacity-100 transition-all duration-300">
                        <div class="p-4 bg-bg-200/90 backdrop-blur-md rounded-full shadow-[0_0_30px_rgba(31,58,95,0.5)] border border-primary-200/30 transform scale-75 group-hover/image:scale-100 transition-transform duration-300">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                          </svg>
                        </div>
                      </div>
                      
                      {/* Badge de clickeable */}
                      <div class="absolute top-3 right-3 px-2 py-1 bg-bg-200/80 backdrop-blur-sm rounded-md border border-primary-200/20 opacity-0 group-hover/image:opacity-100 transition-opacity duration-300">
                        <span class="text-xs text-text-200 flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                          </svg>
                          Click para ampliar
                        </span>
                      </div>
                    </div>
                    
                    {/* Thumbnails */}
                    {link.images.length > 1 && (
                      <div class="gallery-thumbnails flex gap-2 p-2 sm:p-3 bg-bg-100/30 overflow-x-auto scroll-snap-x scroll-smooth scrollbar-hide">
                        {link.images.map((img, imgIdx) => (
                          <button
                            onclick={`cambiarImagen('${img}', ${idx}, this)`}
                            class={`thumbnail-btn flex-shrink-0 w-12 h-9 sm:w-16 sm:h-12 rounded-lg overflow-hidden border-2 transition-all duration-300 hover:scale-110 scroll-snap-align-start ${imgIdx === 0 ? 'border-primary-200 shadow-[0_0_10px_rgba(172,194,239,0.5)]' : 'border-transparent opacity-70 hover:opacity-100'}`}
                            aria-label={`Ver imagen ${imgIdx + 1}`}
                          >
                            <img
                              src={img}
                              alt={`${link.name} - ${imgIdx + 1}`}
                              loading="lazy"
                              decoding="async"
                              class="w-full h-full object-cover"
                            />
                          </button>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              )}

              {/* Spacer */}
              <div class="mt-auto" />

              {/* Botones de acción */}
              <div class="p-5 pt-4 flex flex-col items-center justify-center gap-3 md:flex-row md:justify-center">
                <BordeadoIcon link={link.url} target="_self">
                  <CodeIcon />
                  Código
                </BordeadoIcon>
                {link.despliegue && (
                  <BordeadoIcon link={link.despliegue}>
                    <DeployIcon />
                    Demo
                  </BordeadoIcon>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  {/* Modal ALUCINANTE */}
  <dialog
    id="mimodal"
    class="bg-transparent backdrop:bg-black/90 p-0 w-full h-full max-w-none max-h-none border-none overflow-hidden"
  >
    <div class="relative w-full h-full flex items-center justify-center p-4 md:p-8">
      {/* Fondo con efecto de partículas sutiles */}
      <div class="absolute inset-0 bg-gradient-to-br from-bg-100/95 via-bg-200/95 to-bg-100/95" />
      <div class="absolute inset-0 opacity-30">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-100/30 rounded-full blur-[100px] animate-pulse" />
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent-100/20 rounded-full blur-[80px] animate-pulse" style="animation-delay: 1s" />
      </div>

      {/* Contenedor principal del modal */}
      <div class="modal-content relative w-full max-w-7xl max-h-[90vh] flex flex-col bg-bg-200/80 backdrop-blur-2xl rounded-3xl border border-primary-200/30 shadow-[0_0_100px_rgba(31,58,95,0.6)] overflow-hidden">
        
        {/* Header del modal con efectos */}
        <div class="flex items-center justify-between px-6 py-4 border-b border-primary-200/20 bg-gradient-to-r from-bg-200/50 via-transparent to-bg-200/50">
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-red-500/80 shadow-[0_0_10px_rgba(239,68,68,0.5)]" />
            <div class="w-3 h-3 rounded-full bg-yellow-500/80 shadow-[0_0_10px_rgba(234,179,8,0.5)]" />
            <div class="w-3 h-3 rounded-full bg-green-500/80 shadow-[0_0_10px_rgba(34,197,94,0.5)]" />
            <span class="ml-4 text-sm font-medium text-text-200/70 tracking-wider uppercase">Vista previa del proyecto</span>
          </div>
          
          <button
            onclick="cerrarPopup()"
            class="group p-3 rounded-full bg-bg-300/30 text-text-200 hover:text-text-100 hover:bg-red-500/20 transition-all duration-300 hover:rotate-90 hover:scale-110 border border-transparent hover:border-red-500/30"
            aria-label="Cerrar"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:drop-shadow-[0_0_8px_rgba(239,68,68,0.8)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        {/* Contenedor de imagen principal con efectos */}
        <div class="relative flex-1 flex items-center justify-center p-6 md:p-10 overflow-hidden">
          {/* Glow detrás de la imagen */}
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-[80%] h-[80%] bg-primary-200/10 rounded-full blur-[60px] animate-pulse" />
          </div>
          
          {/* Imagen con contenedor y efectos */}
          <div class="relative group max-w-full max-h-full">
            <div class="absolute -inset-1 bg-gradient-to-r from-primary-200/50 via-accent-200/50 to-primary-200/50 rounded-2xl blur opacity-30 group-hover:opacity-50 transition-opacity duration-500" />
            <img
              id="imagen-popup"
              src=""
              alt="Imagen del proyecto"
              class="relative w-full h-full object-contain max-h-[65vh] rounded-xl shadow-[0_20px_60px_rgba(0,0,0,0.5)] transition-all duration-500 hover:shadow-[0_20px_80px_rgba(31,58,95,0.4)]"
            />
          </div>

          {/* Botones de navegación flotantes laterales */}
          <button 
            onclick="imagenAnterior()"
            id="btn-prev"
            class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 p-4 rounded-full bg-bg-200/80 backdrop-blur-md border border-primary-200/20 text-text-200 hover:text-text-100 hover:bg-primary-100/80 hover:border-primary-200/50 transition-all duration-300 hover:scale-110 hover:shadow-[0_0_30px_rgba(61,90,128,0.5)] group"
            aria-label="Imagen anterior"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          
          <button 
            onclick="imagenSiguiente()"
            id="btn-next"
            class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 p-4 rounded-full bg-bg-200/80 backdrop-blur-md border border-primary-200/20 text-text-200 hover:text-text-100 hover:bg-primary-100/80 hover:border-primary-200/50 transition-all duration-300 hover:scale-110 hover:shadow-[0_0_30px_rgba(61,90,128,0.5)] group"
            aria-label="Imagen siguiente"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
        
        {/* Footer del modal con controles mejorados */}
        <div class="px-6 py-5 border-t border-primary-200/20 bg-gradient-to-r from-bg-200/50 via-transparent to-bg-200/50">
          <div class="flex items-center justify-center gap-8">
            {/* Contador con estilo */}
            <div class="flex items-center gap-3 px-6 py-2 rounded-full bg-bg-300/30 border border-primary-200/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span id="modal-counter" class="text-text-100 font-semibold tracking-wider">1 / 1</span>
            </div>

            {/* Indicadores de progreso */}
            <div id="modal-indicators" class="flex items-center gap-2">
              {/* Los indicadores se generan dinámicamente */}
            </div>
          </div>
        </div>
      </div>
    </div>
  </dialog>
</Section>

<style>
  /* Estilos de la tarjeta de proyecto */
  .project-card {
    background: linear-gradient(145deg, rgba(31, 43, 62, 0.9) 0%, rgba(15, 28, 46, 0.95) 100%);
    border: 1px solid rgba(172, 194, 239, 0.15);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.3),
      0 2px 4px -1px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .project-card:hover {
    transform: translateY(-8px) scale(1.01);
    border-color: rgba(172, 194, 239, 0.4);
    box-shadow: 
      0 20px 40px -10px rgba(31, 58, 95, 0.5),
      0 10px 20px -5px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 0 40px rgba(61, 90, 128, 0.2);
  }

  /* Galería de imágenes */
  .image-gallery {
    border: 1px solid rgba(172, 194, 239, 0.1);
    transition: all 0.3s ease;
  }

  .project-card:hover .image-gallery {
    border-color: rgba(172, 194, 239, 0.25);
    box-shadow: 0 0 20px rgba(61, 90, 128, 0.15);
  }

  /* Scrollbar de thumbnails */
  .gallery-thumbnails::-webkit-scrollbar {
    height: 4px;
  }

  .gallery-thumbnails::-webkit-scrollbar-track {
    background: transparent;
  }

  .gallery-thumbnails::-webkit-scrollbar-thumb {
    background: #4d648d;
    border-radius: 2px;
  }

  /* Modal backdrop animation */
  dialog[open] {
    animation: modalFadeIn 0.3s ease-out;
  }

  dialog[open] > div {
    animation: modalScaleIn 0.3s ease-out;
  }

  @keyframes modalFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes modalScaleIn {
    from { 
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to { 
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Efecto de brillo en hover */
  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(172, 194, 239, 0.06),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    border-radius: inherit;
  }

  .project-card:hover::before {
    opacity: 1;
  }

  /* Estilos adicionales para el modal alucinante */
  dialog::backdrop {
    background: rgba(15, 28, 46, 0.95);
    backdrop-filter: blur(10px);
  }

  .modal-content {
    animation: modalAppear 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes modalAppear {
    from {
      opacity: 0;
      transform: scale(0.9) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Efecto de brillo pulsante en los indicadores */
  @keyframes indicatorPulse {
    0%, 100% {
      box-shadow: 0 0 5px rgba(206, 232, 255, 0.5);
    }
    50% {
      box-shadow: 0 0 15px rgba(206, 232, 255, 0.8), 0 0 25px rgba(206, 232, 255, 0.4);
    }
  }

  #modal-indicators button {
    transition: all 0.3s ease;
  }

  #modal-indicators button:hover {
    transform: scale(1.2);
  }

  /* Transición suave para la imagen del modal */
  #imagen-popup {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Efecto hover en la galería principal */
  .gallery-main {
    position: relative;
    overflow: hidden;
  }

  .gallery-main::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      45deg,
      transparent 30%,
      rgba(172, 194, 239, 0.1) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 0.6s;
  }

  .gallery-main:hover::after {
    transform: translateX(100%);
  }

  /* Animation delay utilities */
  .animation-delay-0 { animation-delay: 0ms; }
  .animation-delay-100 { animation-delay: 100ms; }
  .animation-delay-200 { animation-delay: 200ms; }
  .animation-delay-300 { animation-delay: 300ms; }
  .animation-delay-400 { animation-delay: 400ms; }
  .animation-delay-500 { animation-delay: 500ms; }
  .animation-delay-600 { animation-delay: 600ms; }
  .animation-delay-700 { animation-delay: 700ms; }
  .animation-delay-800 { animation-delay: 800ms; }
  .animation-delay-900 { animation-delay: 900ms; }

  /* Scroll utilities */
  .scroll-snap-x {
    scroll-snap-type: x mandatory;
  }
  
  .scroll-snap-align-start {
    scroll-snap-align: start;
  }
  
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  // Variables globales para el modal
  let imagenesActuales = [];
  let imagenActualIndex = 0;

  // Función para cambiar la imagen principal desde los thumbnails
  window.cambiarImagen = function(src, projectIdx, btnElement) {
    const mainImg = document.getElementById(`main-img-${projectIdx}`);
    if (mainImg) {
      // Fade out
      mainImg.style.opacity = '0.5';
      
      setTimeout(() => {
        mainImg.src = src;
        mainImg.style.opacity = '1';
      }, 150);
    }

    // Actualizar estilos de thumbnails
    const container = btnElement.closest('.gallery-thumbnails');
    if (container) {
      container.querySelectorAll('.thumbnail-btn').forEach(btn => {
        btn.classList.remove('border-primary-200', 'shadow-[0_0_10px_rgba(172,194,239,0.5)]');
        btn.classList.add('border-transparent', 'opacity-70');
      });
      btnElement.classList.remove('border-transparent', 'opacity-70');
      btnElement.classList.add('border-primary-200', 'shadow-[0_0_10px_rgba(172,194,239,0.5)]');
    }
  }

  // Abrir popup con navegación
  window.abrirPopup = function(src, projectIdx) {
    
    // Obtener el contenedor de la galería específico por el id de la imagen principal
    const mainImg = document.getElementById(`main-img-${projectIdx}`);
    if (!mainImg) {
      console.error('No se encontró la imagen principal para el proyecto:', projectIdx);
      // Si no hay imagen principal, usar solo la src pasada
      imagenesActuales = [src];
    } else {
      // Buscar el contenedor de la galería
      const galleryContainer = mainImg.closest('.image-gallery');
      if (galleryContainer) {
        // Obtener todas las imágenes de los thumbnails
        const thumbnailBtns = galleryContainer.querySelectorAll('.thumbnail-btn img');
        if (thumbnailBtns.length > 0) {
          imagenesActuales = Array.from(thumbnailBtns).map(img => img.src);
          console.log('Imágenes encontradas en thumbnails:', imagenesActuales.length);
        } else {
          // Si no hay thumbnails, usar la imagen principal
          imagenesActuales = [mainImg.src];
          console.log('Usando imagen principal solamente');
        }
      } else {
        // Fallback: usar la src pasada
        imagenesActuales = [src];
      }
    }
    
    // Encontrar el índice de la imagen actual
    imagenActualIndex = imagenesActuales.findIndex(img => img === src);
    if (imagenActualIndex === -1) imagenActualIndex = 0;
    
    console.log('Índice de imagen actual:', imagenActualIndex);
    console.log('Total imágenes:', imagenesActuales.length);
    
    // Actualizar modal
    actualizarModal();
    
    // Mostrar modal
    const modal = document.getElementById("mimodal");
    if (modal) {
      modal.showModal();
      // Prevenir scroll del body
      document.body.style.overflow = 'hidden';
    }
  }

  // Actualizar contenido del modal
  function actualizarModal() {
    const img = document.getElementById("imagen-popup");
    const counter = document.getElementById("modal-counter");
    const indicatorsContainer = document.getElementById("modal-indicators");
    const btnPrev = document.getElementById("btn-prev");
    const btnNext = document.getElementById("btn-next");
    
    if (img && imagenesActuales[imagenActualIndex]) {
      // Efecto de transición suave
      img.style.opacity = '0.5';
      img.style.transform = 'scale(0.95)';
      
      setTimeout(() => {
        img.src = imagenesActuales[imagenActualIndex];
        img.style.opacity = '1';
        img.style.transform = 'scale(1)';
      }, 150);
      
      console.log('Cargando imagen en modal:', img.src);
    }
    
    if (counter) {
      counter.textContent = `${imagenActualIndex + 1} / ${imagenesActuales.length}`;
    }

    // Actualizar indicadores de progreso
    if (indicatorsContainer) {
      indicatorsContainer.innerHTML = '';
      imagenesActuales.forEach((_, idx) => {
        const dot = document.createElement('button');
        dot.className = `w-2 h-2 rounded-full transition-all duration-300 ${
          idx === imagenActualIndex 
            ? 'bg-accent-200 w-6 shadow-[0_0_10px_rgba(206,232,255,0.8)]' 
            : 'bg-primary-200/30 hover:bg-primary-200/50'
        }`;
        dot.onclick = () => {
          imagenActualIndex = idx;
          actualizarModal();
        };
        indicatorsContainer.appendChild(dot);
      });
    }

    // Mostrar/ocultar botones de navegación lateral
    if (btnPrev) {
      btnPrev.style.opacity = imagenesActuales.length > 1 ? '1' : '0';
      btnPrev.style.pointerEvents = imagenesActuales.length > 1 ? 'auto' : 'none';
    }
    if (btnNext) {
      btnNext.style.opacity = imagenesActuales.length > 1 ? '1' : '0';
      btnNext.style.pointerEvents = imagenesActuales.length > 1 ? 'auto' : 'none';
    }
  }

  // Navegación del modal
  window.imagenAnterior = function() {
    if (imagenActualIndex > 0) {
      imagenActualIndex--;
      actualizarModal();
    }
  }

  window.imagenSiguiente = function() {
    if (imagenActualIndex < imagenesActuales.length - 1) {
      imagenActualIndex++;
      actualizarModal();
    }
  }

  // Cerrar popup
  window.cerrarPopup = function() {
    const modal = document.getElementById("mimodal");
    if (modal) {
      modal.close();
      document.body.style.overflow = '';
    }
  }

  // Esperar a que el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById("mimodal");
    
    // Cerrar modal al hacer clic fuera
    if (modal) {
      modal.addEventListener("click", (e) => {
        if (e.target === e.currentTarget) {
          window.cerrarPopup();
        }
      });
    }

    // Navegación con teclado
    document.addEventListener("keydown", (e) => {
      const modal = document.getElementById("mimodal");
      if (!modal || !modal.open) return;

      if (e.key === "Escape") {
        window.cerrarPopup();
      } else if (e.key === "ArrowLeft") {
        window.imagenAnterior();
      } else if (e.key === "ArrowRight") {
        window.imagenSiguiente();
      }
    });

    // Efecto de seguimiento del mouse en tarjetas
    document.querySelectorAll('.project-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mouse-x', `${x}px`);
        card.style.setProperty('--mouse-y', `${y}px`);
      });
    });
  });
</script>
