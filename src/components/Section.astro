---
interface Props {
    id: string;
}
const { id } = Astro.props;
---
<div class="mt-16 sm:mt-20 scroll-mt-16 sm:scroll-mt-20" id={id}></div>

<section 
    class="flex flex-col md:flex-row items-start md:items-center justify-between bg-transparent text-text-200 px-4 sm:px-6 md:px-8 py-4 sm:py-6 max-w-6xl mx-auto"
>
    <slot />
</section>
